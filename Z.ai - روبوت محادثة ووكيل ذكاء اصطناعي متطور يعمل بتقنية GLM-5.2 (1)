@charset "utf-8";

:root { --primary: #0D9488; --primary-light: #CCFBF1; --danger: #EF4444; --danger-light: #FEE2E2; --warning: #F59E0B; --success: #10B981; --bg-color: #F8FAFC; --card-bg: #FFFFFF; --text-main: #1E293B; --text-secondary: #64748B; --border-color: #E2E8F0; --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); --transition: all 0.3s ease; }

* { margin: 0px; padding: 0px; box-sizing: border-box; font-family: Tajawal, "Segoe UI", sans-serif; -webkit-tap-highlight-color: transparent; }

body { background-color: var(--bg-color); color: var(--text-main); min-height: 100vh; padding-bottom: 80px; }

header { background-color: var(--primary); color: white; padding: 1rem 1.5rem; display: flex; justify-content: space-between; align-items: center; box-shadow: rgba(13, 148, 136, 0.3) 0px 4px 10px; }

.header-title { font-size: 1.3rem; font-weight: bold; display: flex; align-items: center; gap: 0.5rem; }

.bottom-nav { position: fixed; bottom: 0px; left: 0px; right: 0px; background: var(--card-bg); display: flex; justify-content: space-around; align-items: center; padding: 0.8rem 0px; box-shadow: rgba(0, 0, 0, 0.05) 0px -2px 10px; z-index: 1000; border-top: 1px solid var(--border-color); }

.nav-item { display: flex; flex-direction: column; align-items: center; font-size: 0.75rem; color: var(--text-secondary); cursor: pointer; transition: var(--transition); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: none; font-family: inherit; }

.nav-item i { font-size: 1.3rem; margin-bottom: 0.2rem; }

.nav-item.active { color: var(--primary); font-weight: bold; }

.screen { display: none; padding: 1.5rem; animation: 0.3s ease 0s 1 normal none running fadeIn; }

.screen.active { display: block; }

@keyframes fadeIn { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.family-scroll { display: flex; gap: 1rem; overflow-x: auto; padding-bottom: 1rem; margin-bottom: 1.5rem; }

.family-card { min-width: 100px; background: var(--card-bg); padding: 1rem; border-radius: 12px; text-align: center; box-shadow: var(--shadow); border: 2px solid transparent; cursor: pointer; transition: var(--transition); }

.family-card.active { border-color: var(--primary); background-color: var(--primary-light); }

.family-avatar { font-size: 2.5rem; margin-bottom: 0.5rem; }

.family-name { font-weight: bold; font-size: 0.9rem; }

.med-list { display: flex; flex-direction: column; gap: 0.8rem; }

.med-item { background: var(--card-bg); padding: 1rem; border-radius: 12px; display: flex; align-items: center; gap: 1rem; box-shadow: var(--shadow); border-right: 4px solid var(--primary); }

.med-info h4 { margin-bottom: 0.2rem; }

.med-info p { font-size: 0.85rem; color: var(--text-secondary); }

.med-time { margin-right: auto; background: var(--bg-color); padding: 0.3rem 0.8rem; border-radius: 8px; font-weight: bold; font-size: 0.85rem; }

.scan-area { background: var(--card-bg); border: 2px dashed var(--border-color); border-radius: 16px; padding: 3rem 1rem; text-align: center; margin-bottom: 1.5rem; cursor: pointer; transition: var(--transition); }

.scan-area:hover { border-color: var(--primary); background-color: var(--primary-light); }

.scan-area i { font-size: 3rem; color: var(--primary); margin-bottom: 1rem; }

.input-group { margin-bottom: 1rem; }

.input-group label { display: block; margin-bottom: 0.5rem; font-weight: bold; font-size: 0.9rem; }

.input-group input, .input-group select { width: 100%; padding: 0.8rem 1rem; border: 1px solid var(--border-color); border-radius: 8px; font-size: 1rem; font-family: inherit; background: var(--card-bg); transition: var(--transition); }

.input-group input:focus, .input-group select:focus { outline: none; border-color: var(--primary); box-shadow: rgba(13, 148, 136, 0.1) 0px 0px 0px 3px; }

.alert-box { padding: 1rem; border-radius: 12px; margin-top: 1.5rem; display: none; align-items: flex-start; gap: 0.8rem; font-size: 0.95rem; line-height: 1.5; animation: 0.5s ease-in-out 0s 1 normal none running shake; }

.alert-box.show { display: flex; }

.alert-danger { background: var(--danger-light); color: rgb(153, 27, 27); border: 1px solid rgb(254, 202, 202); }

.alert-warning { background: rgb(255, 251, 235); color: rgb(146, 64, 14); border: 1px solid rgb(253, 230, 138); }

@keyframes shake { 
  0%, 100% { transform: translateX(0px); }
  25% { transform: translateX(-5px); }
  75% { transform: translateX(5px); }
}

.btn-submit { width: 100%; padding: 1rem; background: var(--primary); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 12px; font-size: 1.1rem; font-weight: bold; cursor: pointer; margin-top: 1.5rem; font-family: inherit; transition: var(--transition); }

.btn-submit:disabled { background: rgb(148, 163, 184); cursor: not-allowed; }

.dose-card { background: var(--card-bg); padding: 1.2rem; border-radius: 12px; box-shadow: var(--shadow); display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }

.dose-status { padding: 0.5rem 1.2rem; border-radius: 20px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; font-weight: bold; cursor: pointer; font-family: inherit; transition: var(--transition); }

.dose-pending { background: var(--primary); color: white; }

.dose-taken { background: var(--success); color: white; }

.dose-missed { background: var(--danger); color: white; }
